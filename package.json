{
  "name": "suit-skills",
  "version": "0.0.1",
  "type": "module",
  "description": "A CLI tool for skills management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "suit-skills": "./dist/index.js"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cli",
    "skills"
  ],
  "author": "zhujun",
  "license": "ISC",
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/core": "^11.1.8",
    "@inquirer/prompts": "^8.4.1",
    "commander": "^14.0.3"
  }
}
