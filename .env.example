# ─── MySQL ────────────────────────────────────────────────────────────────────
# Root password used by the healthcheck; not used by the app directly.
MYSQL_ROOT_PASSWORD=change-me-root-password

# Database / app user credentials (must match between mysql and api services)
MYSQL_DATABASE=platform_web
MYSQL_USER=platform_user
MYSQL_PASSWORD=change-me-platform-password

# ─── Platform API ─────────────────────────────────────────────────────────────
# Secret used to sign session cookies. Use a random 32+ char string.
PLATFORM_AUTH_SESSION_SECRET=change-me-min-32-chars-random-secret

# Authentication mode: "local" (database email/password) or "oauth"
PLATFORM_AUTH_MODE=local

# Comma-separated email addresses that get admin role.
PLATFORM_ADMIN_EMAILS=admin@local.dev

# Initial password used only to bootstrap admin accounts that do not yet have a password hash.
# Change it before first startup, then rotate the user password in the database/admin tooling.
PLATFORM_AUTH_BOOTSTRAP_PASSWORD=123456

# ─── Public URLs ─────────────────────────────────────────────────────────────
# The URL where end-users access the web app (used for OAuth redirects & CORS)
PLATFORM_WEB_APP_URL=http://localhost:8080

# The public URL of the API itself (used in OAuth callback construction)
PLATFORM_API_PUBLIC_URL=http://localhost:8080

# Allowed CORS origins for the API (comma-separated if multiple)
PLATFORM_API_CORS_ORIGIN=http://localhost:8080

# ─── Optional overrides ───────────────────────────────────────────────────────
# Override the full database connection URL (skips individual MYSQL_* vars)
# PLATFORM_DATABASE_URL=mysql://user:pass@host:3306/dbname

# Change the host port the web container binds to (default: 8080)
# WEB_PORT=8080

# ─── OAuth / OIDC (only needed when PLATFORM_AUTH_MODE=oauth) ────────────────
# OAUTH_ISSUER_URL=https://your-idp.example.com
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_SCOPES=openid,profile,email
# OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/callback
