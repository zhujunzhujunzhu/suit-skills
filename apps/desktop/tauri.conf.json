{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Suit Skills",
  "version": "1.0.5",
  "identifier": "com.suit-skills.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../.. run dev:web:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm --prefix ../.. run build:all",
    "frontendDist": "../../dist/web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Suit Skills",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://gitee.com https://*.gitee.com https://registry.npmjs.org"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis",
      "deb",
      "appimage",
      "dmg"
    ],
    "externalBin": [
      "binaries/suit-skills"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
